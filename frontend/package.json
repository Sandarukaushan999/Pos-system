{
  "name": "voxo-pos-system",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "VOXO POS System - Professional Point of Sale Solution",
  "author": "VOXO Solutions",
  "homepage": "./",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "electron:start": "cross-env NODE_ENV=production electron .",
    "electron:build": "electron-builder --win --x64",
    "electron:build-all": "electron-builder --win --x64 --publish=never",
    "electron:build-installer": "npm run build && electron-builder --win --x64 --publish=never",
    "electron:build-portable": "npm run build && electron-builder --win portable --x64 --publish=never",
    "dist": "npm run build && npm run electron:build"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "axios": "^1.6.0",
    "chart.js": "^4.2.1",
    "lucide-react": "^0.263.1",
    "moment": "^2.29.4",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.1",
    "tailwindcss": "^4.1.11",
    "zustand": "^4.3.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "cross-env": "^7.0.3",
    "electron": "^29.0.0",
    "electron-builder": "^24.6.0",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "vite": "^7.0.5"
  },
  "main": "electron.js",
  "build": {
    "appId": "com.voxosolutions.pos",
    "productName": "VOXO POS System",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "requestedExecutionLevel": "asInvoker",
      "publisherName": "VOXO Solutions"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "VOXO POS System"
    },
    "portable": {
      "artifactName": "VOXO-POS-Portable.exe"
    },
    "publish": null
  }
}
